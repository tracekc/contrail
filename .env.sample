# ─────────────────────────────────────────────────────────────
# Contrail — 24/7 AI-narrated live air-traffic channel
# Copy to `.env` and fill in. Items marked (REQUIRED) are needed
# for a minimal end-to-end run; (OPTIONAL) can be added later.
#
# NOTE: keep comments on their OWN lines. An inline comment after an
# empty key (KEY=   # note) gets parsed as the key's value by dotenv.
# ─────────────────────────────────────────────────────────────

# ── ADS-B flight data ────────────────────────────────────────
# adsb.lol / adsb.fi are free and need NO key. Default is adsblol
# because it supports BOTH the region query AND the global /squawk/
# endpoint (emergencies worldwide); adsb.fi lacks /squawk/. OpenSky
# gives wider coverage but uses OAuth2 (not wired up in Phase 1).
# Values: adsblol | adsbfi | opensky
ADSB_SOURCE=adsblol
# (OPTIONAL) OpenSky OAuth2 client credentials, from an account at
# opensky-network.org — only if ADSB_SOURCE=opensky.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# ── LLM (narration + dossier color) ──────────────────────────
# (REQUIRED) from console.anthropic.com
ANTHROPIC_API_KEY=
# High-frequency live narration -> cheap/fast model.
LLM_MODEL_LIVE=claude-haiku-4-5-20251001
# Richer dossier prep (later phase) -> stronger model.
LLM_MODEL_DOSSIER=claude-sonnet-4-6

# ── Text-to-speech ───────────────────────────────────────────
# Values: openai (cheap) | elevenlabs (nicer voice) | local (FREE, offline)
# local uses Piper if PIPER_VOICE is set, else macOS `say` (zero install).
# Use local for cost-free experimentation; openai/elevenlabs sound better.
TTS_PROVIDER=openai
# (REQUIRED if TTS_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_TTS_VOICE=onyx
# (OPTIONAL) only if TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# (OPTIONAL) only if TTS_PROVIDER=local
# Path to a Piper neural voice model (.onnx); blank = use macOS `say`.
PIPER_VOICE=
# macOS `say` voice used when Piper isn't configured.
MACOS_SAY_VOICE=Daniel

# ── Web search (dossier "narrative color", later phase) ──────
# Values: claude (native tool, no key) | tavily | brave | none
SEARCH_PROVIDER=claude
TAVILY_API_KEY=
BRAVE_API_KEY=

# ── Aircraft / route enrichment ──────────────────────────────
# (OPTIONAL) route lookups are the one weak free spot; without this,
# origins/destinations are best-effort.
AVIATIONSTACK_API_KEY=

# ── YouTube live output ──────────────────────────────────────
YOUTUBE_RTMP_URL=rtmp://a.rtmp.youtube.com/live2
# (REQUIRED to go live) create a persistent live stream in YouTube
# Studio and copy its stream key here.
YOUTUBE_STREAM_KEY=

# ── Runtime tuning ───────────────────────────────────────────
# ADS-B fetch cadence in seconds (mind free-tier rate limits). The renderer
# dead-reckons between polls, so 15s stays smooth and polite for free feeds.
POLL_INTERVAL_SECONDS=15
# (OPTIONAL) focus a region: lat1,lon1,lat2,lon2. Blank = default (London).
# NOTE: the channel rotates through a built-in region list, so this is
# currently superseded except as the very first region.
COVERAGE_BBOX=
# (OPTIONAL) seconds on each region before the globe-hop. Blank = random
# 10-15 min. Set small (e.g. 20) to preview rotation quickly.
REGION_ROTATE_SECONDS=
# (OPTIONAL) live only: recycle the streamer (Chromium/ffmpeg) this often to
# avoid leaks over days. Default 21600 (6h).
STREAM_RESTART_SECONDS=
TZ=UTC
LOG_LEVEL=info
